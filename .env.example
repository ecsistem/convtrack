# ── Servidor ──────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# URL pública desta API — usada pelo Shield para injetar shield-fp.js via proxy reverso
# Em produção: https://api.seudominio.com
API_BASE_URL=http://localhost:8080

# ── Autenticação ──────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
JWT_SECRET=mude-este-valor-em-producao

# Criptografia AES-256-GCM para credenciais
# Gere com: go run ./scripts/genkey
ENCRYPTION_KEY=base64_de_32_bytes_aleatorios_aqui

# ── Banco de dados ────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/convtrack?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── Webhooks de plataformas ───────────────────────────────────────────────
HOTMART_HOTTOK=seu_token_hotmart
KIWIFY_WEBHOOK_SECRET=seu_secret_kiwify

# ── Session Replay (S3) ───────────────────────────────────────────────────
S3_ENDPOINT=          # vazio = AWS real; http://localhost:4566 = LocalStack
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_DEFAULT_BUCKET=convtrack-replays

# ── Email (SMTP) ──────────────────────────────────────────────────────────
# Usado para recuperação de senha e verificação de email.
# Sem SMTP configurado, o sistema cai em "modo log": imprime o conteúdo do
# email no stdout (útil em desenvolvimento). Em produção, preencha tudo.
# O link do email usa FRONTEND_ORIGIN como base.
SMTP_HOST=                          # ex: smtp.gmail.com, email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587                       # 587 = STARTTLS | 465 = TLS implícito (SMTPS)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                          # remetente; se vazio, usa SMTP_USER
APP_NAME=ConvTrack                  # nome exibido no remetente e templates

# ── Retenção / limpeza de dados ───────────────────────────────────────────
# Job em background remove dados antigos periodicamente (events, sessions sem
# conversão, shield_visits, shield_logs, heatmap_clicks, failed_jobs e tokens).
RETENTION_DAYS=90                   # janela de retenção; <= 0 desabilita o job
RETENTION_INTERVAL_HOURS=6          # frequência de execução da limpeza

# ── DEV: inspeção de webhooks saídos (remova em produção) ─────────────────
# DEV_WEBHOOK_URL=https://quiet-rain-54.webhook.cool

# ── Frontend (docker-compose) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
