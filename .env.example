# ── Servidor ──────────────────────────────────────────────────────────────
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# URL pública desta API — usada pelo Shield para injetar shield-fp.js via proxy reverso
# Em produção: https://api.seudominio.com
API_BASE_URL=http://localhost:8080

# ── Autenticação ──────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
JWT_SECRET=mude-este-valor-em-producao

# Criptografia AES-256-GCM para credenciais
# Gere com: go run ./scripts/genkey
ENCRYPTION_KEY=base64_de_32_bytes_aleatorios_aqui

# ── Banco de dados ────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/convtrack?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── Webhooks de plataformas ───────────────────────────────────────────────
HOTMART_HOTTOK=seu_token_hotmart
KIWIFY_WEBHOOK_SECRET=seu_secret_kiwify

# ── Session Replay (S3) ───────────────────────────────────────────────────
S3_ENDPOINT=          # vazio = AWS real; http://localhost:4566 = LocalStack
S3_REGION=us-east-1
