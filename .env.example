# Server
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# JWT (autenticação de usuários)
# Gere com: openssl rand -base64 32
JWT_SECRET=mude-este-valor-em-producao

# Criptografia de credenciais (AES-256-GCM)
# Gere uma chave com: go run ./scripts/genkey
# Nunca commite este valor
ENCRYPTION_KEY=base64_de_32_bytes_aleatorios_aqui

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/convtrack?sslmode=disable
# Or individual vars:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=convtrack
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Webhook secrets (optional but recommended)
HOTMART_HOTTOK=your_hotmart_token
KIWIFY_WEBHOOK_SECRET=your_kiwify_secret

# Storage para session replays — AWS S3
S3_BUCKET=convtrack-replays
S3_REGION=us-east-1
S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_ENDPOINT= # deixe em branco para AWS real; use http://localhost:4566 para LocalStack

# Dica: em produção use IAM Role em vez de access key — basta omitir S3_ACCESS_KEY e S3_SECRET_KEY
