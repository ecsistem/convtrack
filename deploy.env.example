# ── Config de deploy (copie para deploy.env e ajuste) ──────────────────────
# deploy.env é ignorado pelo git e pelo build. NÃO coloque senhas aqui — a
# autenticação SSH usa sua chave já carregada no ssh-agent.

# Servidor de destino
SSH_HOST=meu-servidor.com         # IP ou hostname
SSH_USER=deploy                   # usuário SSH
SSH_PORT=22                       # porta SSH (default 22)

# Diretório base no servidor (convtrack/ e convtrack-web/ ficam como irmãos aqui)
REMOTE_DIR=/opt/convtrack

# Pular validações locais de build (go build / next build) — true para deploy mais rápido
SKIP_CHECKS=false
